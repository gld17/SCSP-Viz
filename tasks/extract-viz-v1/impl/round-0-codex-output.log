        fixed_sync_overhead_ms=float(normalized["fixed_sync_overhead_ms"]),
        inter_sat_distance_km=float(normalized["inter_sat_distance_km"]),
    )


def dump_config_dict(config: V1SimulationConfig) -> Dict[str, Any]:
    return {
